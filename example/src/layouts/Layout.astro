---
import "jaamd/default.css";
import "jaamd/styles.css";
import MarkdownContent from "jaamd/components";

export interface Props {
  title?: string;
  frontmatter?: { title?: string };
}

const { title, frontmatter } = Astro.props;
const pageTitle = frontmatter?.title ?? title ?? "JAAMD Example";
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{pageTitle}</title>
    <style>
      body {
        margin: 0;
        padding: 2rem;
        max-width: 800px;
        margin-inline: auto;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      }
      nav {
        margin-bottom: 2rem;
        padding-bottom: 1rem;
        border-bottom: 1px solid #e0e0e0;
        display: flex;
        gap: 1rem;
      }
      nav a { color: #2d2d2d; text-decoration: none; font-weight: 500; }
      nav a:hover { text-decoration: underline; }
    </style>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/demo">Demo</a>
    </nav>
    <main>
      <MarkdownContent>
        <slot />
      </MarkdownContent>
    </main>
  </body>
</html>
